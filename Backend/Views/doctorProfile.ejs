<!-- @ts-nocheck -->

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Doctor Profile - Dr. <%= doctor.name %>
    </title>
</head>

<body>

    <nav>
        <div class="logo">
            <img src="/images/Da.png" alt="DocAssist Logo" />
            <h1>DocAssist</h1>
        </div>
        <i id="bar" class="fa-solid fa-bars"></i>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/doctors">Find a Doctor</a></li>
            <li><a href="/contact">Contact Us</a></li>
            <li><a href="/faqs">FAQs</a></li>
            <li id="myAppointments" style="display: none;">
                <a href="/myappointments">My Appointments</a>
            </li>
            <li id="authButton"><a href="/login" class="login-button">Login</a></li>
        </ul>
    </nav>

    <div class="content">
        <div class="profile-container" id="profile">
            <div class="profile-header">
                <img src="/uploads/<%= doctor.photo %>" alt="Doctor's Image" />
                <div>
                    <h1>Dr. <%= doctor.name %>
                    </h1>
                    <p>
                        <%= doctor.speciality %>
                    </p>
                    <p>
                        <%= doctor.qualifications %>
                    </p>
                    <p><strong>
                            <%= doctor.rank %>
                        </strong></p>
                </div>
            </div>

            <div class="rating">
                <span>Satisfied: <%= doctor.satisfactionPercentage %>% (<%= doctor.totalPatients %> patients)</span>
                <div class="progress">
                    <div class="progress-bar"></div>
                </div>
            </div>

            <div class="reviews">
                <h2>Dr. <%= doctor.name %>'s Reviews (<%= doctor.totalPatients %>)</h2>
                <% if (doctor.reviews && doctor.reviews.length> 0) { %>
                    <% doctor.reviews.forEach(function(review) { %>
                        <div class="review-item">
                            <span>
                                <%= review.title %>
                            </span>
                            <% if (review.ratingPercentage) { %>
                                <div class="progress">
                                    <div class="progress-bar"></div>
                                </div>
                                <% } %>
                                    <% if (review.text) { %>
                                        <p class="review-text">
                                            <%= review.text %>
                                        </p>
                                        <% } %>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <p>No reviews yet</p>
                                <% } %>
                                    <div class="view-all">Read all reviews</div>      </div>

           

           

            <div class="education">
                <h2>Education</h2>
                <% doctor.education.forEach(function(edu) { %>
                    <div>
                        <%= edu %>
                    </div>
                    <% }) %>
            </div>

            <div class="experience">
                <h2>Experience</h2>
                <div>
                    <%= doctor.experience %>
                </div>
            </div>

           

            <div class="fees">
                <h2>Fees</h2>
                <div>
                    <%= doctor.fees %>
                </div>
            </div>

            <div class="locations">
                <h2>Practice Locations</h2>
                <% doctor.locations.forEach(function(location) { %>
                    <div>
                        <%= location %>
                    </div>
                    <% }) %>
            </div>

            <div class="days">
                <h2>Available Days</h2>
                <div>Days: <%= doctor.availableDays.join(', ') %></div>
                <div>Time: <%= doctor.availableTime %></div>
            </div>
        </div>

        <div class="booking">
            <h2>Book an Appointment</h2>
        
            <form action="/appointments/book" method="POST">
                <input type="hidden" name="doctorId" value="<%= doctor._id %>" />
        
                <label for="date">Select Date:</label>
                <select name="date" id="date" required>
                    <% doctor.availableDays.forEach(function(day) { %>
                        <option value="<%= day %>">
                            <%= day %>
                        </option>
                        <% }) %>
                </select>
        
                <label for="time">Select Time:</label>
                <select name="time" id="time" required>
                    <!-- You can hardcode times or dynamically generate them -->
                    <option value="10:00 AM">10:00 AM</option>
                    <option value="11:00 AM">11:00 AM</option>
                    <option value="12:00 PM">12:00 PM</option>
                    <option value="01:00 PM">01:00 PM</option>
                    <option value="02:00 PM">02:00 PM</option>
                </select>
        
                <button type="submit">Book Appointment</button>
            </form>
        </div>
          
    </div>

</body>

</html>